# APIBrain Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://apibrain:apibrain@localhost:5432/apibrain
DATABASE_URL_SYNC=postgresql://apibrain:apibrain@localhost:5432/apibrain

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embedding model (via Anthropic's voyage or local)
EMBEDDING_MODEL=voyage-3

# Application
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
