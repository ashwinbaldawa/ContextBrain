# ContextBrain Configuration
# Copy this to .env and fill in your values

# Database (relational data — APIs, endpoints, annotations, logs)
DATABASE_URL=postgresql+asyncpg://contextbrain:contextbrain@localhost:5432/contextbrain
DATABASE_URL_SYNC=postgresql://contextbrain:contextbrain@localhost:5432/contextbrain

# Google Gemini API
GOOGLE_API_KEY=your-google-api-key-here

# Models
GEMINI_LLM_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ChromaDB
# "local" = persistent local storage, "http" = connect to a ChromaDB server
CHROMA_MODE=local
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_COLLECTION_NAME=contextbrain_apis

# Application
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Future: Vertex AI ---
# When migrating to Vertex AI, set these and switch CHROMA_MODE to "vertex"
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# VERTEX_AI_INDEX_ENDPOINT=projects/xxx/locations/xxx/indexEndpoints/xxx
